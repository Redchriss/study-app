# =============================================================================
# Study App (Flutter) - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# ---------- API Configuration ----------
# Base URL for the GraphQL API backend
API_URL=https://api.example.com/graphql

# Full GraphQL endpoint URL
GRAPHQL_URL=https://api.example.com/graphql/

# ---------- Error Tracking (Sentry) ----------
# Sentry DSN for crash/error reporting. Leave empty to disable.
# Get one at: https://sentry.io/settings/projects/
SENTRY_DSN=

# Sentry environment tag (development, staging, production)
SENTRY_ENVIRONMENT=development

# ---------- Firebase (Optional) ----------
# Set to true to enable Firebase analytics and crashlytics
FIREBASE_ENABLED=false
